### Local bashrc file containing system-specific settings

## Set up homebrew paths
# test -d ~/.linuxbrew && eval "$(~/.linuxbrew/bin/brew shellenv)"

########## Prompt ##########
test -e ~/scripts/git-prompt.sh && source ~/scripts/git-prompt.sh
RESTORE='\[\033[0m\]'
# export PS1="${debian_chroot:+(debian_chroot)}\[\033[00;44;30m\][\w]${RESTORE}\[\033[33m\]\$(__git_ps1 \"[\[\033[03m\]%s\033[23m\]]\")${RESTORE} $ "
export PS1="\[\033[00;44;30m\][\w]${RESTORE}\[\033[33m\]\$(__git_ps1 \"[\[\033[03m\]%s\[\033[23m\]]\")${RESTORE} $ "


########## Variables ##########
[[ ":$PATH:" =~ ":${HOME}/local/bin:" ]] || PATH="${HOME}/local/bin:$PATH"
[[ ":$PATH:" =~ ":${HOME}/scripts:" ]] || PATH="${HOME}/scripts:$PATH"
[[ ":$PATH:" =~ ":${HOME}/.cargo/bin:" ]] || PATH="${HOME}/.cargo/bin:$PATH"
[[ ":$LD_LIBRARY_PATH:" =~ ":${HOME}/local/lib:" ]] || LD_LIBRARY_PATH="${HOME}/local/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
# export PKG_CONFIG_PATH=~/local/lib/pkgconfig
MANPATH="~/local/share/man${MANPATH:+:${MATHPATH}}"
INFOPATH="~/conda/share/info"
export PATH LD_LIBRARY_PATH

########## Environment ##########
# export TERM=xterm
export FTP_PASSIVE_MODE=yes
export DISPLAY=":50"

########## Completion ##########
complete -o nospace -F _cd cd # overwrite cd behavior


########## Miniconda ##########
# Activate environment:   conda activate <env>
# Deactivate environment: conda deactivate
if [ -f "${HOME}/conda/etc/profile.d/conda.sh" ]; then
    . "${HOME}/conda/etc/profile.d/conda.sh"
else
    [[ ":$PATH:" =~ ":${HOME}/conda/bin:" ]] || PATH="${HOME}/conda/bin:$PATH"
fi

########## Alias ##########
alias em="emacs-tramp.sh -n"
alias ec="emacs.sh -s cli_server"


########## LSF ##########
if [ -z "${LSF_SHLVL+x}" ]; then
    export LSF_SHLVL=0
    . /tools/support/lsf/conf/profile.lsf
fi
